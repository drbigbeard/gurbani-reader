{
  "name": "gurbani-reader-app",
  "version": "0.11.0-rc.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:native": "tsc -b && NATIVE_BUILD=true vite build",
    "check": "tsc -b --pretty false",
    "audit:pass1": "node scripts/audit-v011-pass1.mjs",
    "audit:rc": "npm run audit:pass1 && node scripts/audit-v011-rc3.mjs",
    "preview": "vite preview",
    "corpus:mobile-db": "node scripts/build-mobile-db.mjs",
    "corpus:upgrade-v2": "node scripts/upgrade-mobile-db-v2.mjs",
    "corpus:fetch-banis": "node scripts/fetch-banidb-banis.mjs",
    "corpus:upgrade-v3": "node scripts/upgrade-mobile-db-v3.mjs",
    "data:upgrade-v4": "node scripts/upgrade-mobile-db-v4.mjs",
    "data:upgrade-v5": "node scripts/upgrade-mobile-db-v5.mjs",
    "corpus:restore": "node scripts/restore-corpus-pack.mjs",
    "native:sync": "npm run build:native && cap sync",
    "android:open": "cap open android",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/cli": "8.4.1",
    "@capacitor/ios": "8.4.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0"
  }
}
